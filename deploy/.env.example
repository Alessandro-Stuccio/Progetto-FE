# Copia questo file in ~/kore/.env (stessa cartella del docker-compose.yml)
# e compila i valori. NON committare il .env vero (contiene segreti).

# Password del database Postgres. Scegline una robusta.
DB_PASSWORD=METTI_UNA_PASSWORD_ROBUSTA

# Segreto per firmare i token JWT. Generane uno casuale e lungo, es:
#   openssl rand -base64 48
JWT_SECRET=METTI_UN_SEGRETO_LUNGO_E_CASUALE

# Il tuo dominio gratuito (vedi DEPLOYMENT.md, sezione DuckDNS).
# Caddy ci ottiene HTTPS in automatico. Niente "http://", solo il dominio.
SITE_ADDRESS=tuonome.duckdns.org
